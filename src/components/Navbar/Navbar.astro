---
import SocraticaWhite from "@/assets/images/SocraticaWhite.svg";
import eye from "./assets/eye.svg?raw";
import heartStraight from "./assets/heart-straight.svg?raw";
import house from "./assets/house.svg?raw";
import mapTrifold from "./assets/map-trifold.svg?raw";
import toolbox from "./assets/toolbox.svg?raw";
import usersThree from "./assets/users-three.svg?raw";
import webring from "./assets/webring.svg?raw";

const currentPath = Astro.url.pathname;

const navLinks = [
  {
    href: "/",
    label: "HOME",
    icon: house,
    isExternal: false,
  },
  {
    href: "/about",
    label: "ABOUT",
    icon: usersThree,
    isExternal: false,
  },
  {
    href: "/map",
    label: "MAP",
    icon: mapTrifold,
    isExternal: false,
  },
  {
    href: "/webring",
    label: "WEBRING",
    icon: webring,
    isExternal: false,
  },
  {
    href: "https://toolbox.socratica.info/",
    label: "TOOLBOX",
    icon: toolbox,
    isExternal: true,
  },
  {
    href: "/get-involved",
    label: "GET INVOLVED",
    icon: eye,
    isExternal: true,
  },
  {
    href: "https://donate.stripe.com/5kA6qZcondXE8Te008",
    label: "DONATE",
    icon: heartStraight,
    isExternal: true,
  },
];
---

<div class="absolute top-4 right-3 z-10">
  <button
    id="nav-toggle"
    class="w-10 h-10 bg-black rounded-full flex flex-col justify-center items-center"
    aria-label="Open navigation"
  >
    <div class="w-3 h-0.5 bg-white mb-1"></div>
    <div class="w-3 h-0.5 bg-white"></div>
  </button>
</div>

<div
  id="nav-overlay"
  class="fixed inset-0 bg-black z-40 hidden"
  style="opacity: 0;"
>
  <button
    id="nav-close"
    class="absolute top-3 right-3 md:top-6 md:right-6 text-white text-2xl leading-none"
    aria-label="Close navigation"
  >
    &times;
  </button>
  <div class="absolute z-50 top-10 left-3 md:left-10">
    <img src={SocraticaWhite.src} alt="Socratica" />
  </div>
  <div
    class="absolute top-40 left-5 md:left-10 flex flex-col space-y-4 items-start z-40"
  >
    {
      navLinks.map((link) => {
        const isActive =
          !link.isExternal &&
          (link.href === "/"
            ? currentPath === "/"
            : currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            target={link.isExternal ? "_blank" : undefined}
            class:list={[
              "nav-link z-40 bg-black text-primary py-2 px-2.5 text-xs md:text-sm rounded-full border border-primary hover:bg-primary hover:text-black font-mono inline-flex items-center space-x-2 transition-colors duration-500 ease-in-out",
              {
                "opacity-50 cursor-not-allowed !bg-primary !text-black":
                  isActive,
              },
            ]}
            data-active={isActive ? "true" : "false"}
          >
            <span
              class="nav-icon w-4 h-4 md:w-6 md:h-6 [&>svg]:w-full [&>svg]:h-full"
              set:html={link.icon}
            />
            <span class:list={[{ "text-black": isActive }]}>{link.label}</span>
          </a>
        );
      })
    }
  </div>
</div>

<script>
  const toggle = document.getElementById("nav-toggle");
  const overlay = document.getElementById("nav-overlay");
  const close = document.getElementById("nav-close");

  function openNav() {
    if (!overlay) return;
    overlay.classList.remove("hidden");
    requestAnimationFrame(() => {
      overlay.style.opacity = "1";
      overlay.style.transition = "opacity 0.5s ease";
    });
  }

  function closeNav() {
    if (!overlay) return;
    overlay.style.opacity = "0";
    setTimeout(() => {
      overlay.classList.add("hidden");
    }, 500);
  }

  toggle?.addEventListener("click", openNav);
  close?.addEventListener("click", closeNav);

  // Close overlay on internal nav link click
  document.querySelectorAll(".nav-link").forEach((link) => {
    const el = link as HTMLElement;
    if (el.dataset.active === "true") {
      el.addEventListener("click", (e) => e.preventDefault());
    } else if (!link.getAttribute("target")) {
      link.addEventListener("click", () => closeNav());
    }
  });
</script>
